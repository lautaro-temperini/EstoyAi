# ─── Pequeños Pasos — variables de entorno de la sede ─────────────────────────
# 1. Copiar este archivo: cp .env.example .env   (Windows: copy .env.example .env)
# 2. Ajustar los valores marcados con  ← CAMBIAR
# 3. Nunca commitear .env (está en .gitignore). NO pongas secretos reales acá.
# ──────────────────────────────────────────────────────────────────────────────

# ── n8n (editor web) ──────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=cambiame          # ← CAMBIAR — password del editor n8n
N8N_API_KEY=                   # ← Obtener en n8n UI → Settings → API → Create an API key
N8N_EDITOR_URL=http://localhost:5678  # URL del editor desde el host (para el script)

# ── URLs internas (no cambiar si usás docker compose sin modificar nombres) ───
N8N_WEBHOOK_URL=http://n8n:5678/webhook/registro
APP_URL=http://app-pwa:3000
WHISPER_URL=http://whisper:8000
OLLAMA_URL=http://ollama:11434

# ── Modelo LLM ────────────────────────────────────────────────────────────────
# qwen3:4b   — mejor calidad (recomendado, ~2.6 GB RAM)
# qwen3:1.7b — más rápido / menos RAM (~1.1 GB RAM)
OLLAMA_MODEL=qwen3:4b

# ── faster-whisper ────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_LANGUAGE=es

# ── PWA (build-time) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ASR_LANG=es

# ── Volumen de datos (vacío = Docker named volume; o ruta Windows para acceso directo) ──
# Ejemplo con bind mount (ver comentario en docker-compose.yml):
# DATA_DIR=/data
