# ─── Pequeños Pasos — variables de entorno de la sede ─────────────────────────
# 1. Copiar este archivo: cp .env.example .env   (Windows: copy .env.example .env)
# 2. Ajustar los valores marcados con  ← CAMBIAR
# 3. Nunca commitear .env (está en .gitignore). NO pongas secretos reales acá.
# ──────────────────────────────────────────────────────────────────────────────

# ── Acceso a la app (HTTP Basic Auth) ────────────────────────────────────────
# Contraseña única de acceso al sistema. El browser pide usuario/contraseña al
# entrar; el usuario se ignora, solo importa la contraseña. Si queda VACÍA, no
# se aplica auth (útil para desarrollo local con `npm run dev`).
# No protege /api/informe/[id]/* (esos los llama n8n desde la red Docker interna).
SITE_PASSWORD=                 # ← CAMBIAR en producción — contraseña de acceso a la app

# ── Multi-tenant por subdominio (una app, varias ONGs) ────────────────────────
# Cada ONG entra por <slug>.estoyai.com con su propia contraseña.
# El slug debe coincidir con el de TENANTS en app-pwa/src/lib/tenants/config.ts.
# Variable por tenant: TENANT_<SLUG_EN_MAYUSCULAS>_PASSWORD. Fallback: SITE_PASSWORD.
ROOT_DOMAIN=estoyai.com              # dominio raíz; apex/www/localhost → tenant default
TENANT_PEQUENOSPASOS_PASSWORD=       # ← contraseña de pequenospasos.estoyai.com
# TENANT_OTRAONG_PASSWORD=           # ← al sumar otra ONG, definí su contraseña acá

# ── n8n (editor web) ──────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=cambiame          # ← CAMBIAR — password del editor n8n
N8N_API_KEY=                   # ← Obtener en n8n UI → Settings → API → Create an API key
N8N_EDITOR_URL=http://localhost:5678  # URL del editor desde el host (para el script)

# ── URLs internas (no cambiar si usás docker compose sin modificar nombres) ───
N8N_WEBHOOK_URL=http://n8n:5678/webhook/registro
APP_URL=http://app-pwa:3000
WHISPER_URL=http://whisper:8000
OLLAMA_URL=http://ollama:11434

# ── Integraciones externas (vía n8n) — opcionales ─────────────────────────────
# Webhooks de n8n que disparan la subida a Cloudflare R2 y el anexo a Podio.
# Si quedan vacíos, los botones de /registros responden "no configurado".
N8N_R2_WEBHOOK_URL=                  # ej: http://n8n:5678/webhook/subir-r2
N8N_PODIO_WEBHOOK_URL=               # ej: http://n8n:5678/webhook/podio

# ── Cloudflare R2 (usado por n8n para subir .docx) ────────────────────────────
# Obtener en dash.cloudflare.com → R2 → Manage API tokens
CF_ACCOUNT_ID=                       # ← ID de cuenta Cloudflare (panel derecho del dashboard)
CF_R2_ACCESS_KEY_ID=                 # ← Access Key ID del token R2
CF_R2_SECRET_ACCESS_KEY=             # ← Secret Access Key del token R2
CF_R2_BUCKET=                        # ← Nombre del bucket (ej: pequenos-pasos-informes)

# ── Podio (usado por n8n para crear/actualizar items) ─────────────────────────
# Obtener en podio.com → Account → API Keys
PODIO_CLIENT_ID=                     # ← Client ID de la app Podio
PODIO_CLIENT_SECRET=                 # ← Client Secret de la app Podio
PODIO_APP_ID=                        # ← ID de la app/espacio donde van los informes

# ── Modelo LLM ────────────────────────────────────────────────────────────────
# gemma3:4b — modelo de producción (el que usa n8n en docker-compose).
# gemma3:1b — más rápido / menos RAM (fallback en CPU lenta).
OLLAMA_MODEL=gemma3:4b

# ── faster-whisper ────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_LANGUAGE=es

# ── PWA (build-time) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_ASR_LANG=es

# ── Volumen de datos (vacío = Docker named volume; o ruta Windows para acceso directo) ──
# Ejemplo con bind mount (ver comentario en docker-compose.yml):
# DATA_DIR=/data
