# --- Pequeños Pasos — variables de entorno de la sede ---------------------
# Copiar a .env y ajustar. docker-compose.yml las inyecta en cada servicio.

# Raíz de los volúmenes compartidos (audio/, docx/, sqlite/).
# En contenedor: /data. En dev local: dejar vacío (usa ../data).
DATA_DIR=/data

# --- Orquestación n8n ------------------------------------------------------
# La PWA dispara este webhook al recibir un audio (POST /api/audio).
# Path del workflow = "registro" (ver n8n/workflows/registro.json).
N8N_WEBHOOK_URL=http://n8n:5678/webhook/registro

# URLs internas que usa el workflow n8n (hostnames de docker-compose).
APP_URL=http://app-pwa:3000
WHISPER_URL=http://whisper:8000
OLLAMA_URL=http://ollama:11434

# Modelo LLM. qwen3:4b (mejor) o qwen3:1.7b (fallback si la CPU no rinde).
OLLAMA_MODEL=qwen3:4b

# --- faster-whisper --------------------------------------------------------
WHISPER_MODEL=base
WHISPER_LANGUAGE=es

# --- PWA (build-time) ------------------------------------------------------
NEXT_PUBLIC_ASR_LANG=es
